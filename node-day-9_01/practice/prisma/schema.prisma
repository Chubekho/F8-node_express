generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id            BigInt    @id @default(autoincrement())
  userame       String?   @unique
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  avatar        String?
  bio           String?
  websiteUrl    String?
  githubUrl     String?
  isVerify      Boolean   @default(false)
  emailVerifyAt DateTime?
  createAt      DateTime  @default(now())
  updateAt      DateTime  @updatedAt
  deleteAt      DateTime?

  posts    Post[]
  comments Comment[]

  @@map("users")
}

model Post {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt
  title       String
  slug        String    @unique
  description String    @db.Text
  content     String    @db.Text
  image       String
  minRead     Int?
  publishedAt DateTime?
  createAt    DateTime  @default(now())
  updateAt    DateTime  @updatedAt
  deleteAt    DateTime?

  user User @relation(fields: [userId], references: [id])

  @@map("posts")
}

model Comment {
  id       BigInt    @id @default(autoincrement())
  userId   BigInt
  content  String
  createAt DateTime  @default(now())
  updateAt DateTime  @updatedAt
  deleteAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@map("comments")
}
